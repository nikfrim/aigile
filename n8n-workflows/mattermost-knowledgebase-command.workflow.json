                                         "jsCode":  "const body = $json.body || $json;\nconst query = (body.text || body.query || \u0027\u0027).trim();\nif (!query) {\n  return [{ json: { ok: false, empty: true, mattermost_payload: { response_type: \u0027ephemeral\u0027, text: \u0027Напиши запрос после команды. Например: /kb что такое Agile?\\n\\nРежимы: /kb --short вопрос, /kb --deep вопрос, /kb --reset\u0027 } } }];\n}\nreturn [{ json: {\n  ok: true,\n  collection: \u0027knowledgebase\u0027,\n  query,\n  channel_id: body.channel_id || \u0027\u0027,\n  channel_name: body.channel_name || \u0027\u0027,\n  user_id: body.user_id || \u0027\u0027,\n  user_name: body.user_name || \u0027\u0027,\n  response_url: body.response_url || \u0027\u0027\n} }];"
                                     },
